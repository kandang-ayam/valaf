# valaf configuration — copy to .env and edit.
# valaf is configured entirely through environment variables: every integration
# is OFF until you set its variables. An unconfigured integration is an honest
# gap, never an error.

# ── PostgreSQL (docker-compose builds VALAF_DATABASE_URL from these) ──────────
POSTGRES_DB=valaf
POSTGRES_USER=valaf
POSTGRES_PASSWORD=change-me

# When NOT using docker-compose, point valaf at your database directly:
# VALAF_DATABASE_URL=postgres://valaf:change-me@localhost:5432/valaf?sslmode=disable

# ── HTTP ──────────────────────────────────────────────────────────────────────
# Host port to publish (compose maps it to the container's 8080)
VALAF_PORT=8080
# Bind address inside the container / on the host
# VALAF_HTTP_ADDR=:8080
# Externally reachable URL — used to build incident links in notifications
VALAF_BASE_URL=http://localhost:8080
# Set true when valaf is served over HTTPS (marks session cookies Secure)
VALAF_SESSION_SECURE=false
# Log level: debug | info | warn | error
VALAF_LOG_LEVEL=info
# Minimum alert severity that opens a notebook: warning | high | critical.
# Default is high — set to warning to also investigate warning-level alerts.
VALAF_SEVERITY_THRESHOLD=high

# ── Evidence collectors (worker) ──────────────────────────────────────────────
# Prometheus-compatible metrics API (Prometheus, Thanos, Mimir, VictoriaMetrics).
# Empty = metrics collector disabled.
VALAF_PROMETHEUS_URL=http://prometheus:9090

# ── AI analysis (worker) ──────────────────────────────────────────────────────
# Provider: anthropic | openai_compat | empty (= no AI; notebooks publish with
# evidence only). openai_compat covers OpenAI, vLLM, Ollama, LiteLLM, gateways.
VALAF_AI_PROVIDER=
# anthropic default:      https://api.anthropic.com
# openai_compat examples: https://api.openai.com/v1  |  http://ollama:11434/v1
VALAF_AI_BASE_URL=
VALAF_AI_API_KEY=
# e.g. claude-sonnet-5 | gpt-4o-mini | llama3.1:8b
VALAF_AI_MODEL=

# ── Notifications (worker; each channel is enabled only when configured) ─────
# Slack incoming webhook
VALAF_SLACK_WEBHOOK_URL=
# Telegram bot (create with @BotFather; chat id of the group/channel/user)
VALAF_TELEGRAM_BOT_TOKEN=
VALAF_TELEGRAM_CHAT_ID=
# Email over SMTP (STARTTLS). VALAF_SMTP_TO is comma-separated.
VALAF_SMTP_HOST=
VALAF_SMTP_PORT=587
VALAF_SMTP_USERNAME=
VALAF_SMTP_PASSWORD=
VALAF_SMTP_FROM=
VALAF_SMTP_TO=
# Generic webhook — structured JSON POST (n8n, Make, custom receivers).
# Optional bearer token sent as Authorization: Bearer <token>.
VALAF_WEBHOOK_URL=
VALAF_WEBHOOK_TOKEN=

# ── Authentication ────────────────────────────────────────────────────────────
# Local accounts always work (bootstrap with: valaf create-user).
# Reverse-proxy SSO mode: trust an identity header set by your auth proxy
# (oauth2-proxy, Authelia, …). ONLY set this when valaf is reachable strictly
# through that proxy — anyone who can reach valaf directly could forge it.
# VALAF_TRUSTED_PROXY_HEADER=X-Forwarded-User

# S3/MinIO vars set → backend = s3
VALAF_S3_ENDPOINT=http://minio:9000
VALAF_S3_BUCKET=valaf-snapshots
VALAF_S3_ACCESS_KEY=… / VALAF_S3_SECRET_KEY=…

# nothing set → backend = local volume (default, zero config)
# VALAF_DATA_DIR=/var/lib/valaf   (optional; has a sane default)