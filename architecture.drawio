        <mxCell id="sec_h" parent="1" style="text;html=1;align=left;verticalAlign=middle;fontSize=15;fontStyle=1;fontColor=#b85450;" value="Security &amp; governance  (cross-cutting)" vertex="1">
          <mxGeometry height="26" width="500" x="40" y="900" as="geometry" />
        </mxCell>
        <mxCell id="sec" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;spacingRight=8;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" value="Two credential planes&#xa;&#xa;① INBOUND — per-source intake: shared token / HMAC&#xa;② OUTBOUND — read-only, per-backend scoped creds (never write verbs)&#xa;+ single AI egress (may be internal)&#xa;&#xa;No command execution, anywhere." vertex="1">
          <mxGeometry height="170" width="410" x="40" y="932" as="geometry" />
        </mxCell>
        <mxCell id="roles" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;spacingRight=8;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" value="Roles (RBAC)&#xa;&#xa;viewer — read only&#xa;engineer — edit · hypothesis verdicts · flag evidence invalid · write resolution · flag notebook FALSE (petition to admin)&#xa;admin — DELETE notebook · users · settings" vertex="1">
          <mxGeometry height="170" width="410" x="470" y="932" as="geometry" />
        </mxCell>
        <mxCell id="audit" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;spacingRight=8;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" value="Audit log (append-only) + mutability&#xa;&#xa;every verdict · flag · resolution · delete → who / what / when; survives a purged notebook.&#xa;IMMUTABLE — raw evidence + audit log&#xa;EDITABLE (engineer) — verdicts, flags, resolution&#xa;DELETABLE (admin) — whole notebook: soft-delete → purge (DB + snapshot files)" vertex="1">
          <mxGeometry height="170" width="410" x="900" y="932" as="geometry" />
        </mxCell>
