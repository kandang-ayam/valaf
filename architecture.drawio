        </mxCell>
        <mxCell id="efb" edge="1" parent="1" source="s6" style="endArrow=block;html=1;dashed=1;strokeWidth=2;strokeColor=#9673a6;fontSize=11;fontColor=#6a4a86;exitX=0;exitY=0.5;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" target="learn" value="resolved + verdicts → learning &amp; triage tuning">
          <mxGeometry relative="1" as="geometry">
