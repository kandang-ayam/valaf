        <mxCell id="incidents" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;spacingRight=6;fontSize=11;fillColor=#dce9f7;strokeColor=#2f4a6b;strokeWidth=2;" value="&lt;b&gt;incidents&lt;/b&gt;  ◆ the notebook&lt;br&gt;────────────&lt;br&gt;&lt;u&gt;id&lt;/u&gt; uuid  PK&lt;br&gt;title text&lt;br&gt;status enum(open,analyzing,published,&lt;br&gt;  resolved,false_positive,deleted)&lt;br&gt;severity enum(high,critical)&lt;br&gt;grouping_key text&lt;br&gt;entity_bag jsonb  (service/host/pod/env)&lt;br&gt;triage_verdict enum · null&lt;br&gt;FK assigned_to → users · null&lt;br&gt;notified bool&lt;br&gt;opened_at · published_at&lt;br&gt;resolved_at · deleted_at (soft-delete)" vertex="1">
          <mxGeometry height="230" width="320" x="700" y="300" as="geometry" />
