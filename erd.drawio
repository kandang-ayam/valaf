        <mxCell id="attachments" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;spacingRight=6;fontSize=11;fillColor=#eef4e2;strokeColor=#55801a;" value="&lt;b&gt;attachments&lt;/b&gt;  (blob store, not DB)&lt;br&gt;────────────&lt;br&gt;&lt;u&gt;id&lt;/u&gt; uuid  PK&lt;br&gt;FK evidence_item_id → evidence_items&lt;br&gt;storage_backend enum(local,s3)&lt;br&gt;storage_key text  (path / object key)&lt;br&gt;mime_type · size_bytes · checksum&lt;br&gt;created_at" vertex="1">
          <mxGeometry height="130" width="300" x="330" y="620" as="geometry" />
