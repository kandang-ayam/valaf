        <mxCell id="title" parent="1" style="text;html=1;align=left;verticalAlign=middle;fontSize=22;fontStyle=1;fontColor=#3c5514;" value="valaf — database ERD  (PostgreSQL)" vertex="1">
          <mxGeometry height="30" width="900" x="40" y="16" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" parent="1" style="text;html=1;align=left;verticalAlign=middle;fontSize=12;fontColor=#666666;" value="The notebook = the incidents aggregate. Evidence &amp; audit_log are immutable. Binary snapshots live on disk (attachments row references the file). Exports are generated on demand, never persisted → no table.   Crow&#39;s-foot: ●&lt; = many, ┃ = one." vertex="1">
          <mxGeometry height="20" width="1400" x="40" y="46" as="geometry" />
        </mxCell>
        <mxCell id="sessions" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;spacingRight=6;fontSize=11;fillColor=#fbeeee;strokeColor=#b85450;" value="&lt;b&gt;sessions&lt;/b&gt;&lt;br&gt;────────────&lt;br&gt;&lt;u&gt;id&lt;/u&gt; uuid  PK&lt;br&gt;FK user_id → users&lt;br&gt;token_hash text&lt;br&gt;csrf_secret text&lt;br&gt;created_at · expires_at" vertex="1">
          <mxGeometry height="120" width="250" x="40" y="90" as="geometry" />
        </mxCell>
        <mxCell id="users" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;spacingRight=6;fontSize=11;fillColor=#fbeeee;strokeColor=#b85450;" value="&lt;b&gt;users&lt;/b&gt;&lt;br&gt;────────────&lt;br&gt;&lt;u&gt;id&lt;/u&gt; uuid  PK&lt;br&gt;username text  UQ&lt;br&gt;email text&lt;br&gt;password_hash text · null&lt;br&gt;auth_source enum(local,proxy,oidc)&lt;br&gt;external_id text · null  (oidc sub)&lt;br&gt;role enum(viewer,engineer,admin)&lt;br&gt;is_active bool&lt;br&gt;last_login_at · created_at" vertex="1">
          <mxGeometry height="160" width="250" x="40" y="250" as="geometry" />
        </mxCell>
        <mxCell id="audit_log" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;spacingRight=6;fontSize=11;fillColor=#fbeeee;strokeColor=#b85450;" value="&lt;b&gt;audit_log&lt;/b&gt;  (append-only)&lt;br&gt;────────────&lt;br&gt;&lt;u&gt;id&lt;/u&gt; bigserial  PK&lt;br&gt;FK actor_id → users · null&lt;br&gt;action text&lt;br&gt;entity_type · entity_id  (polymorphic)&lt;br&gt;details jsonb&lt;br&gt;at timestamptz" vertex="1">
          <mxGeometry height="140" width="250" x="40" y="450" as="geometry" />
        </mxCell>
        <mxCell id="alerts" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;spacingRight=6;fontSize=11;fillColor=#eef4e2;strokeColor=#55801a;" value="&lt;b&gt;alerts&lt;/b&gt;&lt;br&gt;────────────&lt;br&gt;&lt;u&gt;id&lt;/u&gt; uuid  PK&lt;br&gt;FK incident_id → incidents&lt;br&gt;source enum(alertmanager,grafana,&lt;br&gt;  datadog,newrelic,generic)&lt;br&gt;fingerprint text&lt;br&gt;severity text&lt;br&gt;labels jsonb · annotations jsonb&lt;br&gt;raw_payload jsonb&lt;br&gt;starts_at · ends_at · received_at" vertex="1">
          <mxGeometry height="190" width="300" x="330" y="70" as="geometry" />
        </mxCell>
        <mxCell id="evidence_items" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;spacingRight=6;fontSize=11;fillColor=#eef4e2;strokeColor=#55801a;" value="&lt;b&gt;evidence_items&lt;/b&gt;  (immutable)&lt;br&gt;────────────&lt;br&gt;&lt;u&gt;id&lt;/u&gt; uuid  PK&lt;br&gt;FK incident_id → incidents&lt;br&gt;collector enum(prometheus,loki,&lt;br&gt;  elasticsearch,grafana,kubernetes)&lt;br&gt;kind enum(metric,log,dashboard,orch)&lt;br&gt;request jsonb  (reproducible query)&lt;br&gt;result jsonb · null&lt;br&gt;status enum(ok,gap,failed)&lt;br&gt;error text · null&lt;br&gt;is_valid bool  (flag only, never edit)&lt;br&gt;invalid_comment text · null&lt;br&gt;FK flagged_by → users · null&lt;br&gt;flagged_at · captured_at" vertex="1">
          <mxGeometry height="270" width="300" x="330" y="300" as="geometry" />
